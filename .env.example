PORT=4000
NODE_ENV=development

# Opción A: URL (misma forma que otras apps)
# DATABASE_URL=mysql://usuario:password@localhost:3306/homeops

# Opción B: variables sueltas
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=homeops_user
DB_PASSWORD=cambiar_en_local
DB_NAME=homeops

CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

JWT_SECRET=cambiar_en_produccion
JWT_EXPIRES_IN=7d
ACTIVATION_TOKEN_HOURS=48

# SMTP (opcional; sin SMTP el enlace se imprime en consola del backend)
# Gmail: usar contraseña de aplicación (2FA activo), no la contraseña de la cuenta
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu_cuenta@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx
# SMTP_FROM=tu_cuenta@gmail.com
# Si falla "self-signed certificate in certificate chain" (antivirus/proxy):
# SMTP_TLS_REJECT_UNAUTHORIZED=false

# Google OAuth (futuro; fuera de alcance E1)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
